# Цель: Redmi AC2100
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_redmi-router-ac2100=y

# Luci и Локализация (RU + EN, без китайского)
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_ru=y
CONFIG_LUCI_LANG_en=y
# CONFIG_LUCI_LANG_zh-cn is not set

# VPN (Tailscale)
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_tailscaled=y
CONFIG_PACKAGE_luci-app-tailscale=y

# Блокировка рекламы
CONFIG_PACKAGE_luci-app-adblock=y
CONFIG_PACKAGE_luci-i18n-adblock-ru=y

# HTTPS поддержка (критично для скачивания списков и работы VPN)
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_ca-bundle=y

# Оптимизация и Скорость
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_kmod-nft-offload=y

# Вырезаем поддержку USB (на AC2100 её нет физически)
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb-ohci is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb-ledtrig-usbport is not set

# Wi-Fi (Базовая поддержка шифрования)
CONFIG_PACKAGE_wpad-basic-openssl=y
